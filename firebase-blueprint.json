{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created"
        }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "PalmReading": {
      "title": "PalmReading",
      "description": "A saved palm reading result",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this reading"
        },
        "resultData": {
          "type": "string",
          "description": "The compressed or JSON stringified result data"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the reading was created"
        }
      },
      "required": ["userId", "resultData", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/readings/{readingId}": {
      "schema": { "$ref": "#/entities/PalmReading" },
      "description": "Saved palm readings"
    }
  }
}
